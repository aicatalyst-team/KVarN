# KVarN: Variance-Normalized KV-Cache Quantization for vLLM
# Uses official vLLM v0.23.0 image as base to avoid long CUDA compilation
# Overlays KVarN modifications using editable install

FROM vllm/vllm-openai:v0.23.0 AS base

USER root
WORKDIR /opt/kvarn

# Copy KVarN source
COPY . .

# Overlay KVarN modifications on top of installed vLLM v0.23.0
# Strategy: copy KVarN's modified Python files over the installed vLLM package
# This preserves the compiled C extensions (vllm._C) from the base image
RUN VLLM_SITE=$(python3 -c "import vllm; import os; print(os.path.dirname(vllm.__file__))") && \
    echo "Overlaying KVarN files onto $VLLM_SITE" && \
    cp -r /opt/kvarn/vllm/* "$VLLM_SITE/" && \
    python3 -c "import vllm; print('vLLM version:', vllm.__version__)" && \
    python3 -c "from vllm.v1.attention.backends.registry import AttentionBackendRegistry; print('KVarN backend registered:', 'KVARN' in [b.name for b in AttentionBackendRegistry])"

# Copy the non-root entrypoint script (handles OpenShift arbitrary UIDs)
COPY docker/entrypoints/vllm-nonroot-entrypoint.sh /usr/local/bin/vllm-nonroot-entrypoint.sh
RUN chmod 0755 /usr/local/bin/vllm-nonroot-entrypoint.sh

# OpenShift compatibility: create vllm user, make /etc/passwd group-0 writable
# for arbitrary UID injection, ensure all cache dirs are group-0 writable
RUN useradd -u 2000 -g 0 -m -d /home/vllm vllm 2>/dev/null || true && \
    mkdir -p /home/vllm/.cache/huggingface /home/vllm/.triton /home/vllm/.cache/vllm && \
    chgrp -R 0 /home/vllm && chmod -R g=u /home/vllm && \
    chgrp -R 0 /opt/kvarn && chmod -R g=u /opt/kvarn && \
    chmod g+w /etc/passwd

EXPOSE 8000

USER 2000
WORKDIR /home/vllm

ENV HF_HOME=/home/vllm/.cache/huggingface
ENV TRITON_CACHE_DIR=/home/vllm/.triton
ENV VLLM_CACHE_ROOT=/home/vllm/.cache/vllm

ENTRYPOINT ["/usr/local/bin/vllm-nonroot-entrypoint.sh"]
